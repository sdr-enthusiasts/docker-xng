#!/command/with-contenv bash
# shellcheck shell=bash
# shellcheck source-path=source-stubs
# shellcheck source-path=SCRIPTDIR

source /scripts/common

XNG_BIN="/opt/xng"

# Resolve which station config to run: a user-supplied one wins,
# otherwise the one generated by 01-xng.
if [[ -n "${XNG_CONFIG}" ]]; then
    CONFIG_PATH="${XNG_CONFIG}"
else
    CONFIG_PATH="/run/xng/station.toml"
fi

XNG_CMD=()

# Global flags come before the subcommand.
if [[ -n "${XNG_VERBOSE}" ]]; then
    # XNG_VERBOSE may be a count (1,2,3) or a -v/-vv/-vvv string.
    case "${XNG_VERBOSE}" in
    1) XNG_CMD+=("-v") ;;
    2) XNG_CMD+=("-vv") ;;
    3) XNG_CMD+=("-vvv") ;;
    -v | -vv | -vvv) XNG_CMD+=("${XNG_VERBOSE}") ;;
    *) "${s6wrap[@]}" echo "Ignoring invalid XNG_VERBOSE='${XNG_VERBOSE}' (want 1, 2 or 3)" ;;
    esac
fi

if [[ -n "${XNG_DECODE_THREADS}" ]]; then
    XNG_CMD+=("--decode-threads" "${XNG_DECODE_THREADS}")
fi

XNG_CMD+=("station" "${CONFIG_PATH}")

"${s6wrap[@]}" echo "Starting: '${XNG_BIN}" "${XNG_CMD[*]}'"

exec "${s6wrap[@]}" "${XNG_BIN}" "${XNG_CMD[@]}"
