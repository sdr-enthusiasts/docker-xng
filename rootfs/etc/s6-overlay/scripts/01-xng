#!/command/with-contenv bash
# shellcheck shell=bash
# shellcheck source-path=source-stubs
# shellcheck source-path=SCRIPTDIR

source /scripts/common

GENERATED_CONFIG="/run/xng/station.toml"

mkdir -p /run/xng

# ──────────────────────────────────────────────────────────────
# A user-supplied config wins outright. We validate it exists and
# skip generation entirely.
# ──────────────────────────────────────────────────────────────
if [[ -n "${XNG_CONFIG}" ]]; then
    if [[ ! -f "${XNG_CONFIG}" ]]; then
        "${s6wrap[@]}" echo "XNG_CONFIG is set to '${XNG_CONFIG}' but no such file exists, exiting"
        exit 1
    fi
    "${s6wrap[@]}" echo "Using user-supplied station config: ${XNG_CONFIG}"
    exit 0
fi

# ──────────────────────────────────────────────────────────────
# Otherwise we generate a station config from the environment.
#
# Sessions are indexed. Session 1 uses the UNSUFFIXED vars
# (XNG_MODE, XNG_SERIAL, …). Sessions 2..N use a numeric suffix
# (XNG_MODE_2, XNG_SERIAL_2, …). We walk the indices in order and
# stop at the first index that defines no session at all. Outputs
# (XNG_HTTP, XNG_JSONL, …) are global — unsuffixed only.
#
# STATION_ID is always required. Each session requires MODE and an
# SDR (XNG_SDR_n verbatim, or composed from DRIVER/SERIAL/BIASTEE).
# ──────────────────────────────────────────────────────────────
if [[ -z "${XNG_STATION_ID}" ]]; then
    "${s6wrap[@]}" echo "XNG_STATION_ID is not set, exiting"
    exit 1
fi

# session_var BASE INDEX  →  echo the value of XNG_<BASE> (index 1) or
# XNG_<BASE>_<INDEX> (index >= 2). Empty when unset.
session_var() {
    local base="$1" idx="$2" name
    if [[ "${idx}" -eq 1 ]]; then
        name="XNG_${base}"
    else
        name="XNG_${base}_${idx}"
    fi
    printf '%s' "${!name:-}"
}

# session_defined INDEX  →  true if any identifying var for this session
# index is set (used to find where the session list ends).
session_defined() {
    local idx="$1"
    [[ -n "$(session_var SDR "${idx}")" ]] && return 0
    [[ -n "$(session_var DRIVER "${idx}")" ]] && return 0
    [[ -n "$(session_var SERIAL "${idx}")" ]] && return 0
    [[ -n "$(session_var MODE "${idx}")" ]] && return 0
    return 1
}

# compose_sdr INDEX  →  echo the SDR selector string for this session.
# A per-session XNG_SDR[_n] wins verbatim; otherwise compose from the
# DRIVER/SERIAL/BIASTEE split vars. Exits non-zero (with a message) when
# neither an SDR string nor a driver is available.
compose_sdr() {
    local idx="$1" sdr driver serial biastee args
    sdr="$(session_var SDR "${idx}")"
    if [[ -n "${sdr}" ]]; then
        printf '%s' "${sdr}"
        return 0
    fi
    driver="$(session_var DRIVER "${idx}")"
    serial="$(session_var SERIAL "${idx}")"
    # A serial with no explicit driver defaults to rtlsdr (the common case,
    # and what the unsuffixed XNG_DRIVER default already implies for
    # session 1). With neither a driver nor a serial there is nothing to
    # build a selector from.
    if [[ -z "${driver}" ]]; then
        if [[ -n "${serial}" ]]; then
            driver="rtlsdr"
        else
            return 1
        fi
    fi
    biastee="$(session_var BIASTEE "${idx}")"
    args="driver=${driver}"
    [[ -n "${serial}" ]] && args+=",serial=${serial}"
    if chk_enabled "${biastee}"; then
        args+=",bias=1"
    fi
    printf '%s' "${args}"
}

# Helper: emit `key = "value"` only when value is non-empty.
emit_str() {
    local key="$1" val="$2"
    [[ -z "${val}" ]] && return 0
    printf '%s = "%s"\n' "${key}" "${val}" >>"${GENERATED_CONFIG}"
}

# Helper: emit `key = value` (unquoted, for numbers/bools) when non-empty.
emit_raw() {
    local key="$1" val="$2"
    [[ -z "${val}" ]] && return 0
    printf '%s = %s\n' "${key}" "${val}" >>"${GENERATED_CONFIG}"
}

# Helper: emit a TOML array of quoted strings from a list separated by
# commas, semicolons, or whitespace (the sdr-enthusiasts FREQUENCIES style).
emit_array() {
    local key="$1" list="$2"
    [[ -z "${list}" ]] && return 0
    local -a items=()
    IFS='; ,' read -ra _parts <<<"${list}"
    for p in "${_parts[@]}"; do
        [[ -z "${p}" ]] && continue
        items+=("\"${p}\"")
    done
    [[ "${#items[@]}" -eq 0 ]] && return 0
    local joined
    joined=$(
        IFS=,
        echo "${items[*]}"
    )
    printf '%s = [%s]\n' "${key}" "${joined}" >>"${GENERATED_CONFIG}"
}

# Start fresh every boot.
: >"${GENERATED_CONFIG}"

{
    printf '# Generated by docker-xng from environment. Do not edit.\n'
    printf 'station-id = "%s"\n\n' "${XNG_STATION_ID}"
    printf '[outputs]\n'
} >>"${GENERATED_CONFIG}"

if chk_enabled "${XNG_FEED_AIRFRAMES}"; then
    emit_raw "feed-airframes" "true"
fi
if chk_enabled "${XNG_JSON}"; then
    emit_raw "json" "true"
fi
emit_str "jsonl" "${XNG_JSONL}"
emit_str "metrics" "${XNG_METRICS}"
emit_str "http" "${XNG_HTTP}"
emit_str "sbs" "${XNG_SBS}"
emit_str "beast" "${XNG_BEAST}"
emit_str "nmea-tcp" "${XNG_NMEA_TCP}"
emit_str "nmea-udp" "${XNG_NMEA_UDP}"
emit_str "mqtt" "${XNG_MQTT}"
emit_str "mqtt-topic" "${XNG_MQTT_TOPIC}"
emit_array "udp" "${XNG_UDP}"

# ──────────────────────────────────────────────────────────────
# Emit each session. Walk indices from 1 upward; stop at the first
# index that defines no session. Guard against index gaps so a
# misnumbered var (e.g. _2 and _4 but no _3) fails loudly instead of
# silently dropping a decoder.
# ──────────────────────────────────────────────────────────────
emit_session() {
    local idx="$1" mode sdr

    mode="$(session_var MODE "${idx}")"
    if [[ -z "${mode}" ]]; then
        "${s6wrap[@]}" echo "Session ${idx}: MODE is not set, exiting"
        exit 1
    fi

    if ! sdr="$(compose_sdr "${idx}")" || [[ -z "${sdr}" ]]; then
        "${s6wrap[@]}" echo "Session ${idx}: no SDR set (need XNG_SDR${idx_suffix} or XNG_DRIVER${idx_suffix}), exiting"
        exit 1
    fi

    {
        printf '\n[[session]]\n'
    } >>"${GENERATED_CONFIG}"

    emit_str "sdr" "${sdr}"
    emit_str "mode" "${mode}"
    emit_raw "gain" "$(session_var GAIN "${idx}")"
    emit_raw "sample-rate" "$(session_var SAMPLE_RATE "${idx}")"
    emit_str "center" "$(session_var CENTER "${idx}")"
    emit_array "channels" "$(session_var CHANNELS "${idx}")"
    emit_str "receiver-pos" "$(session_var RECEIVER_POS "${idx}")"
    emit_str "demod-effort" "$(session_var DEMOD_EFFORT "${idx}")"
}

SESSION_COUNT=0
idx=1
while session_defined "${idx}"; do
    if [[ "${idx}" -eq 1 ]]; then idx_suffix=""; else idx_suffix="_${idx}"; fi
    emit_session "${idx}"
    SESSION_COUNT=$((SESSION_COUNT + 1))
    idx=$((idx + 1))
done

if [[ "${SESSION_COUNT}" -eq 0 ]]; then
    "${s6wrap[@]}" echo "No session defined (set XNG_MODE + an SDR), exiting"
    exit 1
fi

# Gap check: if a higher index is defined past where we stopped, the
# user almost certainly misnumbered. Scan a reasonable window ahead.
gap_end=$((idx + 16))
probe="${idx}"
while [[ "${probe}" -le "${gap_end}" ]]; do
    if session_defined "${probe}"; then
        "${s6wrap[@]}" echo "Session index gap: session ${probe} is defined but session ${idx} is not. Sessions must be numbered consecutively from 1. Exiting"
        exit 1
    fi
    probe=$((probe + 1))
done

"${s6wrap[@]}" echo "Configured ${SESSION_COUNT} session(s)."
"${s6wrap[@]}" echo "Generated station config at ${GENERATED_CONFIG}:"
"${s6wrap[@]}" cat "${GENERATED_CONFIG}"

# Everything is good to go. Exit with 0
exit 0
